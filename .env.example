# Wayfinder Configuration
# Copy this to .env and fill in your values

# Claude API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model for standard chat (claude-sonnet-4-6 recommended for cost efficiency)
CLAUDE_MODEL=claude-sonnet-4-6

# Model for paid-tier Engine pulls (Coach/Consultant get Opus 4.6)
# Set this to claude-opus-4-6 in production for paid users
CLAUDE_MODEL_ENGINE=claude-opus-4-6

# Server
PORT=3001
NODE_ENV=development

# Optional: USAJobs API key (free at developer.usajobs.gov)
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Optional: Data.gov API key (free at api.data.gov)
DATA_GOV_API_KEY=

# Knowledge base path
KNOWLEDGE_BASE_PATH=./knowledge-base

# Session storage
SESSION_STORE_PATH=./data/sessions

# Feedback storage
FEEDBACK_STORE_PATH=./data/feedback

# Scraper output
SCRAPER_OUTPUT_PATH=./data/scraped

# ---- Stripe Payment Configuration (REQUIRED for payments) ----
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-key-here
# Admissions Subscription Price IDs (Coach $25/mo, Consultant $50/mo)
STRIPE_PRICE_PRO=price_your-coach-25-id
STRIPE_PRICE_ELITE=price_your-consultant-50-id
# Career Subscription Price IDs (Career Pro $15/mo, Career Elite $30/mo)
STRIPE_PRICE_CAREER_PRO=price_your-career-pro-15-id
STRIPE_PRICE_CAREER_ELITE=price_your-career-elite-30-id
# Essay Credit Pack Price IDs (one-time payments)
STRIPE_PRICE_ESSAY_5=price_your-5pack-id
STRIPE_PRICE_ESSAY_10=price_your-10pack-id
STRIPE_PRICE_ESSAY_20=price_your-20pack-id
# Webhook signing secret from Stripe Dashboard > Webhooks > Signing secret
# CRITICAL: This MUST be set in production — webhooks will be rejected without it
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# ---- Security Configuration ----
# REQUIRED in production: Your frontend URL for CORS
FRONTEND_URL=https://wayfinderai.org
# Application URL (for Stripe redirect URLs)
APP_URL=https://wayfinderai.org
# Admin secret for admin routes
ADMIN_SECRET=your-admin-secret-here
# Admin emails (comma-separated) - can switch plans to test tier behavior
ADMIN_EMAILS=danielyungkim@hotmail.com
# VIP emails (comma-separated) - always get elite-tier access
VIP_EMAILS=mhrkim@yahoo.com
