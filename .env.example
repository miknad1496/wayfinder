# Wayfinder Configuration
# Copy this to .env and fill in your values

# Claude API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use (claude-sonnet-4-6 recommended for cost efficiency)
CLAUDE_MODEL=claude-sonnet-4-6

# Server
PORT=3001
NODE_ENV=development

# Optional: USAJobs API key (free at developer.usajobs.gov)
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Optional: Data.gov API key (free at api.data.gov)
DATA_GOV_API_KEY=

# Knowledge base path
KNOWLEDGE_BASE_PATH=./knowledge-base

# Session storage
SESSION_STORE_PATH=./data/sessions

# Feedback storage
FEEDBACK_STORE_PATH=./data/feedback

# Scraper output
SCRAPER_OUTPUT_PATH=./data/scraped

# ---- Stripe Payment Configuration (REQUIRED for payments) ----
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_your-key-here
# Price IDs from Stripe Dashboard > Products > Pricing
STRIPE_PRICE_PREMIUM=price_your-premium-id
STRIPE_PRICE_PRO=price_your-pro-id
# Webhook signing secret from Stripe Dashboard > Webhooks > Signing secret
# CRITICAL: This MUST be set in production — webhooks will be rejected without it
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# ---- Security Configuration ----
# REQUIRED in production: Your frontend URL for CORS
FRONTEND_URL=https://wayfinderai.org
# Application URL (for Stripe redirect URLs)
APP_URL=https://wayfinderai.org
# Admin secret for admin routes
ADMIN_SECRET=your-admin-secret-here
