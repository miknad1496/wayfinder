# Wayfinder Configuration
# Copy this to .env and fill in your values

# Claude API Key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to use (claude-sonnet-4-6 recommended for cost efficiency)
CLAUDE_MODEL=claude-sonnet-4-6

# Server
PORT=3001
NODE_ENV=development

# Optional: USAJobs API key (free at developer.usajobs.gov)
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Optional: Data.gov API key (free at api.data.gov)
DATA_GOV_API_KEY=

# Knowledge base path
KNOWLEDGE_BASE_PATH=./knowledge-base

# Session storage
SESSION_STORE_PATH=./data/sessions

# Feedback storage
FEEDBACK_STORE_PATH=./data/feedback

# Scraper output
SCRAPER_OUTPUT_PATH=./data/scraped
